# Base domain for platform services (apps get their own domains in app.yaml).
# Services: db.<BASE_DOMAIN>, logs.<BASE_DOMAIN>, tail.<BASE_DOMAIN>, mq.<BASE_DOMAIN>
BASE_DOMAIN=example.com

# Let's Encrypt + OpenObserve login email
ACME_EMAIL=you@example.com

# Generated by install.sh if left empty
PG_PASSWORD=
OO_PASSWORD=
RABBITMQ_PASSWORD=

# htpasswd entry for Dozzle (generated by install.sh).
# Note: $ signs must be doubled ($$) inside compose env files.
DOZZLE_AUTH=
