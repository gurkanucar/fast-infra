# Generated by `platform` from app.yaml — do not edit by hand.
# Set `manual: true` in app.yaml to take over this file yourself.
name: app-{{.Name}}

services:
  app:
    image: {{.Image}}:${TAG:-latest}
    restart: unless-stopped
    env_file:
      - .env
    environment:
      # app.yaml's `port` is authoritative: the app must listen here. Most
      # 12-factor apps read $PORT; if yours uses a different variable
      # (e.g. Spring's SERVER_PORT), set that in .env to the same value.
      - PORT={{.Port}}
    # No container healthcheck: the platform probes {{.Health}} over HTTP from
    # the host during deploys, so the image needs no wget/curl of its own.
    labels:
      - traefik.enable=true
      - traefik.http.routers.{{.Name}}.rule=Host(`{{.Domain}}`)
      - traefik.http.routers.{{.Name}}.tls.certresolver=le
      - traefik.http.routers.{{.Name}}.middlewares={{.Name}}-retry
      - traefik.http.services.{{.Name}}.loadbalancer.server.port={{.Port}}
      # During a rolling swap the old replica stops accepting connections a
      # moment before Traefik drops it from rotation, which would otherwise
      # surface as a stray 502. Retry transparently re-routes such a request
      # to a healthy replica (the new one is already up during the overlap).
      - traefik.http.middlewares.{{.Name}}-retry.retry.attempts=3
      - traefik.http.middlewares.{{.Name}}-retry.retry.initialinterval=100ms
    networks: [platform]

networks:
  platform:
    external: true
